    border: 1px solid #dee2e6;
    border-radius: 6px;
    outline: 0;  /* 删除焦点虚线 */
    border: none;  /* 删除边框 */
}

QTableWidget:focus {
    outline: 0;  /* 删除焦点虚线 */
}

QTableWidget::item {
    padding: 6px;
    border-bottom: 1px solid #f0f0f0;
}

QTableWidget::item:selected {
    background-color: rgba(135, 206, 235, 0.5);  /* 浅蓝色，不透明度50% */
    color: black;
}

QTableWidget::item:focus {
    background-color: rgba(30, 144, 255, 0.7);  /* 深蓝色，不透明度70% - 美化焦点样式 */
    color: black;  /* 保持黑色文字 */
    border: none;  /* 删除边框 */
}

QTableWidget::item:selected:focus {
    background-color: rgba(30, 144, 255, 0.9);  /* 更深的蓝色，不透明度90% - 选中且焦点状态 */
    color: black;  /* 保持黑色文字 */
}

QHeaderView::section {
