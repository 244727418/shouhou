/* 对话框整体样式 */
QDialog {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #f8f9fa, stop: 1 #e9ecef);
    border: 1px solid #dee2e6;
    border-radius: 8px;
}

/* 标签样式 */
QLabel {
    font-family: "YouYuan";
    font-size: 14px;
    color: #495057;
    font-weight: bold;
}

/* 输入框样式 */
QLineEdit {
    font-family: "YouYuan";
    font-size: 12px;
    padding: 8px 12px;
    border: 2px solid #e9ecef;
    border-radius: 6px;
    background-color: white;
    selection-background-color: #4CAF50;
}

QLineEdit:focus {
    border-color: #4CAF50;
    background-color: #f8fff8;
}

QLineEdit:placeholder {
    color: #adb5bd;
    font-style: italic;
}

/* 按钮样式 */
QPushButton {
    font-family: "YouYuan";
    font-size: 12px;
    font-weight: bold;
    padding: 8px 20px;
    border: none;
    border-radius: 6px;
    min-width: 80px;
}

/* 添加按钮 */
QPushButton#add_btn {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #4CAF50, stop: 1 #45a049);
    color: white;
}

QPushButton#add_btn:hover {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #45a049, stop: 1 #3d8b40);
}

QPushButton#add_btn:pressed {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #3d8b40, stop: 1 #357935);
}

/* 取消按钮 */
QPushButton#cancel_btn {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #6c757d, stop: 1 #5a6268);
    color: white;
}

QPushButton#cancel_btn:hover {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #5a6268, stop: 1 #545b62);
}

QPushButton#cancel_btn:pressed {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #545b62, stop: 1 #4e555b);
}
