  <property name="styleSheet">
   <string notr="true">
/* 对话框整体样式 */
QDialog {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #f8f9fa, stop: 1 #e9ecef);
    border: 1px solid #dee2e6;
    border-radius: 8px;
}

/* 标签样式 */
QLabel {
    font-family: "YouYuan";
    font-size: 14px;
    color: #495057;
    font-weight: bold;
}

/* 输入框样式 */
QLineEdit {
    font-family: "YouYuan";
    font-size: 12px;
    padding: 8px 12px;
    border: 2px solid #e9ecef;
    border-radius: 6px;
    background-color: white;
    selection-background-color: #2196F3;
}

QLineEdit:focus {
    border-color: #2196F3;
    background-color: #f8fbff;
}

QLineEdit:placeholder {
    color: #adb5bd;
    font-style: italic;
}

/* 按钮样式 */
QPushButton {
    font-family: "YouYuan";
    font-size: 12px;
    font-weight: bold;
    padding: 8px 20px;
    border: none;
    border-radius: 6px;
    min-width: 80px;
}

/* 保存按钮 */
QPushButton#save_btn {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #2196F3, stop: 1 #1976D2);
    color: white;
}

QPushButton#save_btn:hover {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #1976D2, stop: 1 #1565C0);
}

QPushButton#save_btn:pressed {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #1565C0, stop: 1 #0D47A1);
}

/* 取消按钮 */
QPushButton#cancel_btn {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #6c757d, stop: 1 #5a6268);
    color: white;
}

QPushButton#cancel_btn:hover {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #5a6268, stop: 1 #545b62);
}

QPushButton#cancel_btn:pressed {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #545b62, stop: 1 #4e555b);
}

/* 特殊标签样式 */
QLabel#or_label, QLabel#percent_label {
    color: #6c757d;
    font-weight: normal;
    font-style: italic;
}
   </string>
